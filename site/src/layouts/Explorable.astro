---
// Shared shell for the Phase 1 topic explorables: warm-paper page, topbar,
// hero, the sticky-canvas scrollytelling grid, outro, and prev/next pager.
// The page supplies the narrative scenes (default slot) and a <script> in the
// "script" slot; everything else comes from props so each topic stays thin and
// every page reads as one instrument.
import { href } from "../lib/href";

interface Legend {
  accent: "context" | "action" | "verified" | "risk" | "purple";
  label: string;
}
interface Neighbor {
  title: string;
  path: string;
}
interface Props {
  title: string;
  description: string;
  backHref: string;
  backLabel: string;
  tag: string;
  eyebrow: string;
  h1: string;
  lede: string;
  canvasId: string;
  canvasAria: string;
  legend: Legend[];
  outroEyebrow: string;
  outroTitle: string;
  outroBody: string;
  prev?: Neighbor;
  next?: Neighbor;
  fallbackHref: string; // where the "next" pager points when there is no next
  fallbackLabel: string;
}

const p = Astro.props as Props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={p.description} />
    <link rel="icon" href={href("favicon.svg")} />
    <title>{p.title}</title>
  </head>
  <body>
    <header class="topbar">
      <a class="topbar-back" href={p.backHref}>← {p.backLabel}</a>
      <span class="topbar-tag">{p.tag}</span>
    </header>

    <main id="main">
      <section class="hero">
        <p class="eyebrow">{p.eyebrow}</p>
        <h1>{p.h1}</h1>
        <p class="lede">{p.lede}</p>
        <p class="scroll-hint">Scroll to begin ↓</p>
      </section>

      <section class="scrolly">
        <div class="narrative">
          <slot />
        </div>
        <div class="visual">
          <div class="visual-inner">
            <canvas id={p.canvasId} role="img" aria-label={p.canvasAria}></canvas>
            <ul class="legend" aria-hidden="true">
              {
                p.legend.map((l) => (
                  <li class={`leg leg--${l.accent}`}>
                    <span class="leg-dot" /> {l.label}
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </section>

      <section class="outro">
        <p class="eyebrow">{p.outroEyebrow}</p>
        <h2>{p.outroTitle}</h2>
        <p>{p.outroBody}</p>
      </section>

      <nav class="pager" aria-label="Phase 1 navigation">
        {p.prev ? <a class="pager-link" href={href(p.prev.path)}>← {p.prev.title}</a> : <span />}
        {
          p.next ? (
            <a class="pager-link pager-next" href={href(p.next.path)}>
              {p.next.title} →
            </a>
          ) : (
            <a class="pager-link pager-next" href={href(p.fallbackHref)}>
              {p.fallbackLabel} →
            </a>
          )
        }
      </nav>
    </main>

    <style is:global>
      :root {
        --paper: #fbfaf6;
        --paper-2: #ffffff;
        --ink: #221f1a;
        --ink-soft: #5c554b;
        --ink-faint: #968d7d;
        --hair: #e6e0d4;
        --hair-strong: #d6cdbb;
        --context: #2f6bd8;
        --action: #c9740a;
        --verified: #1f9a63;
        --risk: #d6453f;
        --purple: #7a5af0;
        --serif: "Iowan Old Style", "Palatino Linotype", Palatino, "Book Antiqua", Georgia, ui-serif,
          serif;
        --sans: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial,
          sans-serif;
        --mono: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
      }

      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--sans);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px clamp(20px, 5vw, 56px);
        border-bottom: 1px solid var(--hair);
        position: sticky;
        top: 0;
        background: color-mix(in srgb, var(--paper) 92%, transparent);
        z-index: 20;
      }
      .topbar-back {
        color: var(--ink);
        text-decoration: none;
        font-weight: 600;
        font-size: 15px;
      }
      .topbar-back:hover {
        color: var(--context);
      }
      .topbar-tag {
        font-family: var(--mono);
        font-size: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--ink-faint);
      }

      main {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 clamp(20px, 5vw, 56px);
      }

      .eyebrow,
      .scene-eyebrow {
        font-family: var(--mono);
        font-size: 12.5px;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        color: var(--action);
        margin: 0 0 14px;
      }

      .hero {
        padding: clamp(52px, 10vh, 116px) 0 clamp(36px, 7vh, 72px);
        max-width: min(72ch, 100%);
      }
      .hero h1 {
        font-family: var(--serif);
        font-weight: 600;
        font-size: clamp(34px, 6vw, 60px);
        line-height: 1.06;
        letter-spacing: -0.015em;
        margin: 0 0 26px;
      }
      .lede {
        font-size: clamp(18px, 2.2vw, 22px);
        line-height: 1.55;
        color: var(--ink-soft);
        max-width: 58ch;
        margin: 0 0 34px;
      }
      .scroll-hint {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--ink-faint);
        letter-spacing: 0.04em;
        margin: 0;
      }

      .scrolly {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: clamp(24px, 5vw, 72px);
        align-items: start;
      }
      .narrative {
        padding-block: 6vh 10vh;
      }
      .scene {
        min-height: 84vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        max-width: 44ch;
      }
      .scene h2 {
        font-family: var(--serif);
        font-weight: 600;
        font-size: clamp(25px, 3.4vw, 36px);
        line-height: 1.12;
        letter-spacing: -0.01em;
        margin: 0 0 18px;
      }
      .scene p {
        font-size: clamp(17px, 1.9vw, 20px);
        line-height: 1.62;
        color: var(--ink-soft);
        margin: 0;
      }

      .visual {
        position: sticky;
        top: 11vh;
        align-self: start;
        height: min(78vh, 600px);
      }
      .visual-inner {
        background: var(--paper-2);
        border: 1px solid var(--hair);
        border-radius: 18px;
        box-shadow:
          0 1px 2px rgba(40, 38, 32, 0.04),
          0 18px 40px -24px rgba(40, 38, 32, 0.22);
        height: 100%;
        padding: 18px 18px 14px;
        display: flex;
        flex-direction: column;
      }
      .visual-inner canvas {
        width: 100%;
        flex: 1;
        display: block;
      }
      .legend {
        display: flex;
        flex-wrap: wrap;
        gap: 6px 18px;
        list-style: none;
        margin: 8px 0 0;
        padding: 12px 4px 2px;
        border-top: 1px solid var(--hair);
      }
      .leg {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 12.5px;
        color: var(--ink-soft);
        font-weight: 500;
      }
      .leg-dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        display: inline-block;
      }
      .leg--context .leg-dot {
        background: var(--context);
      }
      .leg--action .leg-dot {
        background: var(--action);
      }
      .leg--verified .leg-dot {
        background: var(--verified);
      }
      .leg--risk .leg-dot {
        background: var(--risk);
      }
      .leg--purple .leg-dot {
        background: var(--purple);
      }

      /* shared interactive control styles (picker / toggles) */
      .controls {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 26px;
      }
      .ctl {
        font-family: var(--sans);
        font-size: 15px;
        font-weight: 600;
        padding: 11px 16px;
        border-radius: 11px;
        border: 1.5px solid var(--hair-strong);
        background: var(--paper-2);
        color: var(--ink);
        cursor: pointer;
        transition:
          border-color 0.16s ease,
          background 0.16s ease,
          transform 0.1s ease;
      }
      .ctl:hover {
        transform: translateY(-1px);
        border-color: var(--context);
      }
      .ctl[aria-pressed="true"] {
        border-color: var(--context);
        background: color-mix(in srgb, var(--context) 10%, var(--paper-2));
        color: color-mix(in srgb, var(--context) 72%, var(--ink));
      }
      .ctl:focus-visible {
        outline: 2px solid var(--context);
        outline-offset: 2px;
      }

      .outro {
        max-width: 60ch;
        padding: clamp(40px, 9vh, 110px) 0 clamp(28px, 5vh, 48px);
      }
      .outro h2 {
        font-family: var(--serif);
        font-weight: 600;
        font-size: clamp(26px, 3.6vw, 40px);
        line-height: 1.1;
        margin: 0 0 18px;
        letter-spacing: -0.012em;
      }
      .outro p {
        font-size: clamp(17px, 2vw, 20px);
        line-height: 1.6;
        color: var(--ink-soft);
        margin: 0;
      }
      .pager {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        border-top: 1px solid var(--hair);
        padding: 22px 0 clamp(64px, 12vh, 120px);
      }
      .pager-link {
        color: var(--context);
        text-decoration: none;
        font-weight: 600;
        font-size: 16px;
      }
      .pager-link:hover {
        text-decoration: underline;
      }
      .pager-next {
        margin-left: auto;
      }

      @media (max-width: 820px) {
        .scrolly {
          grid-template-columns: 1fr;
        }
        .visual {
          position: sticky;
          top: 64px;
          height: 44vh;
          order: -1;
          margin-bottom: 8px;
        }
        .scene {
          min-height: 68vh;
          max-width: none;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        .ctl {
          transition: none;
        }
      }
    </style>
  </body>
</html>
