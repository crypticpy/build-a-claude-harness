---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sv5Memory from '../../components/viz/Sv5Memory.astro';
import { href } from '../../lib/href';
import facts from '../../generated/facts.json';
---

<BaseLayout
  title="SV-5 · Per-Repo Intelligence & Memory Stack · Harness Atlas"
  phase="1"
  description="Per-repo intelligence is four cheap layers, and only one of them — the brain, at compaction — ever pays the LLM."
>
  <main id="main" class="viz-page">
    <p class="eyebrow"><a href={href('phase-1')}>Lesson 1</a> · Signature visualization 5</p>
    <h1>Where does the money go?</h1>
    <p class="lede">
      Per-repo intelligence is built from four cheap layers. Three of them run on plain string
      ops and file appends: free, instant, fail-silent. Step through the tool calls and watch
      the rolling log fill for nothing. Only the last tier, the brain at PreCompact, ever pays
      the LLM. One finger, and the money lights up in exactly one place.
    </p>

    <Sv5Memory />

    <p class="provenance mono">
      Tiers pinned to real modules (<code>session-start.mjs</code>, <code>rolling-log.mjs</code>,
      <code>precompact-llm.mjs</code>) at <code>{(facts as { shortSha?: string }).shortSha}</code>.
      The 8000-token figure is illustrative; the one-LLM-call topology is the fact.
    </p>
  </main>
</BaseLayout>

<style>
  .viz-page { max-width: 1040px; margin: 0 auto; padding: var(--sp-8) var(--sp-6) var(--sp-12); }
  .eyebrow { font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--ink-faint); letter-spacing: 0.04em; }
  .eyebrow a { color: var(--ink-muted); }
  h1 { font-family: var(--font-display); font-size: var(--fs-3xl); line-height: 1.1; margin: var(--sp-2) 0 var(--sp-4); color: var(--ink); }
  .lede { font-size: var(--fs-lg); line-height: 1.5; color: var(--ink-muted); max-width: 64ch; margin-bottom: var(--sp-6); }
  .provenance { margin-top: var(--sp-8); font-size: var(--fs-2xs); color: var(--ink-faint); max-width: 70ch; }
  .provenance code { color: var(--ink-muted); }
</style>
