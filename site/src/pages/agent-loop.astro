---
import { href } from "../lib/href";
import { SCENES, LEGEND } from "../lib/agentLoop";

const REPO = "https://github.com/crypticpy/build-a-claude-harness";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="An explorable: watch a Claude Code harness turn one plain request into finished, checked work, one step of the agent loop at a time."
    />
    <link rel="icon" href={href("favicon.svg")} />
    <title>The Agent Loop · Harness Atlas</title>
  </head>
  <body>
    <header class="topbar">
      <a class="topbar-back" href={href()}>← Harness Atlas</a>
      <span class="topbar-tag">Explorable · preview</span>
    </header>

    <main id="main">
      <section class="hero">
        <p class="eyebrow">The agent loop</p>
        <h1>How a harness turns a request<br />into working software.</h1>
        <p class="lede">
          The model writes the words. The <em>harness</em> is everything built around it that turns
          those words into real, checked work: reading your project, planning, using tools, and
          testing what it made. Here is that loop, one step at a time.
        </p>
        <p class="scroll-hint">Scroll to begin ↓</p>
      </section>

      <section class="al-scrolly">
        <div class="al-narrative">
          {
            SCENES.map((s) => (
              <article class="al-step" data-scene={s.id}>
                <p class="al-eyebrow">{s.eyebrow}</p>
                <h2>{s.title}</h2>
                <p>{s.body}</p>
                {s.id === "play" && (
                  <div class="al-controls">
                    <button id="al-run-strong" class="al-btn al-btn--strong" aria-pressed="false" type="button">
                      Run with a strong harness
                    </button>
                    <button id="al-run-weak" class="al-btn al-btn--weak" aria-pressed="false" type="button">
                      Run with a weak harness
                    </button>
                  </div>
                )}
              </article>
            ))
          }
        </div>

        <div class="al-visual">
          <div class="al-visual-inner">
            <canvas
              id="al-canvas"
              role="img"
              aria-label="A six-stage agent loop: goal, gather context, plan, use a tool, verify, evaluate, with a return arrow from evaluate back to plan."
            ></canvas>
            <ul class="al-legend" aria-hidden="true">
              {
                LEGEND.map((l) => (
                  <li class={`leg leg--${l.accent}`}>
                    <span class="leg-dot" /> {l.label}
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </section>

      <section class="outro">
        <p class="eyebrow">The whole point</p>
        <h2>The harness is the difference.</h2>
        <p>
          Same model, both times. The strong run read the project first and checked its own work, so a
          failed test became a fix instead of a bug. The weak run skipped both and shipped the bug. That
          gap, not the model, is what this whole site is about.
        </p>
        <p class="outro-links">
          <a href={href("phase-1")}>See the harness, piece by piece →</a>
          <a href={REPO} rel="noopener">Source on GitHub</a>
        </p>
      </section>
    </main>

    <script>
      import { initAgentLoop } from "../scripts/agentLoopCanvas";
      initAgentLoop();
    </script>

    <style is:global>
      :root {
        --paper: #fbfaf6;
        --paper-2: #ffffff;
        --ink: #221f1a;
        --ink-soft: #5c554b;
        --ink-faint: #968d7d;
        --hair: #e6e0d4;
        --hair-strong: #d6cdbb;
        --context: #2f6bd8;
        --action: #c9740a;
        --verified: #1f9a63;
        --risk: #d6453f;
        --serif: "Iowan Old Style", "Palatino Linotype", Palatino, "Book Antiqua", Georgia, ui-serif,
          serif;
        --sans: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial,
          sans-serif;
        --mono: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
      }

      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--sans);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px clamp(20px, 5vw, 56px);
        border-bottom: 1px solid var(--hair);
        position: sticky;
        top: 0;
        background: color-mix(in srgb, var(--paper) 92%, transparent);
        z-index: 20;
      }
      .topbar-back {
        color: var(--ink);
        text-decoration: none;
        font-weight: 600;
        font-size: 15px;
      }
      .topbar-back:hover {
        color: var(--context);
      }
      .topbar-tag {
        font-family: var(--mono);
        font-size: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--ink-faint);
      }

      main {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 clamp(20px, 5vw, 56px);
      }

      .eyebrow,
      .al-eyebrow {
        font-family: var(--mono);
        font-size: 12.5px;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        color: var(--action);
        margin: 0 0 14px;
      }

      .hero {
        padding: clamp(56px, 11vh, 128px) 0 clamp(40px, 8vh, 80px);
        max-width: min(72ch, 100%);
      }
      .hero h1 {
        font-family: var(--serif);
        font-weight: 600;
        font-size: clamp(34px, 6vw, 62px);
        line-height: 1.06;
        letter-spacing: -0.015em;
        margin: 0 0 28px;
      }
      .lede {
        font-size: clamp(18px, 2.2vw, 22px);
        line-height: 1.55;
        color: var(--ink-soft);
        max-width: 56ch;
        margin: 0 0 36px;
      }
      .lede em {
        font-style: normal;
        color: var(--ink);
        border-bottom: 2px solid color-mix(in srgb, var(--action) 55%, transparent);
        padding-bottom: 1px;
      }
      .scroll-hint {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--ink-faint);
        letter-spacing: 0.04em;
        margin: 0;
      }

      /* ---- scrollytelling layout ---- */
      .al-scrolly {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: clamp(24px, 5vw, 72px);
        align-items: start;
      }
      .al-narrative {
        padding-block: 6vh 10vh;
      }
      .al-step {
        min-height: 84vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        max-width: 44ch;
      }
      .al-step h2 {
        font-family: var(--serif);
        font-weight: 600;
        font-size: clamp(25px, 3.4vw, 36px);
        line-height: 1.12;
        letter-spacing: -0.01em;
        margin: 0 0 18px;
      }
      .al-step p {
        font-size: clamp(17px, 1.9vw, 20px);
        line-height: 1.62;
        color: var(--ink-soft);
        margin: 0;
      }

      .al-visual {
        position: sticky;
        top: 11vh;
        align-self: start;
        height: min(78vh, 600px);
      }
      .al-visual-inner {
        background: var(--paper-2);
        border: 1px solid var(--hair);
        border-radius: 18px;
        box-shadow:
          0 1px 2px rgba(40, 38, 32, 0.04),
          0 18px 40px -24px rgba(40, 38, 32, 0.22);
        height: 100%;
        padding: 18px 18px 14px;
        display: flex;
        flex-direction: column;
      }
      #al-canvas {
        width: 100%;
        flex: 1;
        display: block;
      }
      .al-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 6px 18px;
        list-style: none;
        margin: 8px 0 0;
        padding: 12px 4px 2px;
        border-top: 1px solid var(--hair);
      }
      .leg {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 12.5px;
        color: var(--ink-soft);
        font-weight: 500;
      }
      .leg-dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        display: inline-block;
      }
      .leg--context .leg-dot {
        background: var(--context);
      }
      .leg--action .leg-dot {
        background: var(--action);
      }
      .leg--verified .leg-dot {
        background: var(--verified);
      }
      .leg--risk .leg-dot {
        background: var(--risk);
      }

      /* ---- play controls ---- */
      .al-controls {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 28px;
      }
      .al-btn {
        font-family: var(--sans);
        font-size: 15px;
        font-weight: 600;
        padding: 12px 18px;
        border-radius: 11px;
        border: 1.5px solid var(--hair-strong);
        background: var(--paper-2);
        color: var(--ink);
        cursor: pointer;
        transition:
          border-color 0.16s ease,
          background 0.16s ease,
          transform 0.1s ease;
      }
      .al-btn:hover {
        transform: translateY(-1px);
      }
      .al-btn--strong:hover,
      .al-btn--strong[aria-pressed="true"] {
        border-color: var(--verified);
        background: color-mix(in srgb, var(--verified) 10%, var(--paper-2));
        color: color-mix(in srgb, var(--verified) 72%, var(--ink));
      }
      .al-btn--weak:hover,
      .al-btn--weak[aria-pressed="true"] {
        border-color: var(--risk);
        background: color-mix(in srgb, var(--risk) 10%, var(--paper-2));
        color: color-mix(in srgb, var(--risk) 72%, var(--ink));
      }
      .al-btn:focus-visible {
        outline: 2px solid var(--context);
        outline-offset: 2px;
      }

      /* ---- outro ---- */
      .outro {
        max-width: 60ch;
        padding: clamp(48px, 10vh, 120px) 0 clamp(72px, 14vh, 140px);
      }
      .outro h2 {
        font-family: var(--serif);
        font-weight: 600;
        font-size: clamp(26px, 3.6vw, 40px);
        line-height: 1.1;
        margin: 0 0 18px;
        letter-spacing: -0.012em;
      }
      .outro p {
        font-size: clamp(17px, 2vw, 20px);
        line-height: 1.6;
        color: var(--ink-soft);
        margin: 0 0 24px;
      }
      .outro-links {
        display: flex;
        flex-wrap: wrap;
        gap: 14px 28px;
      }
      .outro-links a {
        color: var(--context);
        text-decoration: none;
        font-weight: 600;
        font-size: 16px;
      }
      .outro-links a:hover {
        text-decoration: underline;
      }

      @media (max-width: 820px) {
        .al-scrolly {
          grid-template-columns: 1fr;
        }
        .al-visual {
          position: sticky;
          top: 64px;
          height: 46vh;
          order: -1;
          margin-bottom: 8px;
        }
        .al-step {
          min-height: 70vh;
          max-width: none;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        .al-btn {
          transition: none;
        }
      }
    </style>
  </body>
</html>
