---
import BaseLayout from '../layouts/BaseLayout.astro';
import { href } from '../lib/href';
import facts from '../generated/facts.json';

const learn = [
  'Why a session turn is really a trip through five lifecycle events, and what a hook can do at each one.',
  'How a single router dispatches every hook, so adding behavior never means rewiring the system.',
  'How a hook can fail quietly instead of taking your whole turn down with it.',
  'How the agent keeps its memory across hours of work and a context compaction.',
  'How commands, skills, and subagents divide the labor between you and the model.',
  'How a second model gates the few actions you cannot undo, which is what makes an unattended run safe.',
];
---

<BaseLayout title="Harness Atlas — how a Claude Code agent runs on its own" phase="1">
  <main id="main" class="wrap landing">
    <section class="hero">
      <p class="kicker mono">A VISUAL GUIDE TO ONE REAL HARNESS</p>
      <h1 class="hero-line">How a Claude Code agent is wired to run on its own.</h1>
      <p class="tagline prose">
        Sixteen short, visual modules take a working harness apart: the hooks, the memory, the
        subagents, and the approval gate that let a coding agent run for hours without a human
        watching. No setup, no code to write. Just the architecture, shown plainly.
      </p>

      <div class="cta-row">
        <a class="btn btn-primary" href={href('phase-1/lifecycle-wire')}>Start with module 1</a>
        <a class="btn btn-ghost" href={href('phase-1')}>Browse all 16 modules</a>
      </div>

      <p class="meta-line mono">
        Two phases · 16 modules · about 90 minutes · free, no signup · readable without JavaScript
      </p>
    </section>

    <section class="learn" aria-labelledby="learn-h">
      <h2 id="learn-h" class="section-h">What you will come away understanding</h2>
      <ol class="learn-grid">
        {
          learn.map((item, i) => (
            <li class="learn-item">
              <span class="learn-num mono">{String(i + 1).padStart(2, '0')}</span>
              <span class="learn-text">{item}</span>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="phases" aria-labelledby="phases-h">
      <h2 id="phases-h" class="section-h">The two phases</h2>
      <nav class="phase-nav" aria-label="Phases">
        <a class="phase-card" href={href('phase-1')}>
          <span class="phase-tag mono">PHASE 1 · 8 MODULES</span>
          <span class="phase-title">Foundations</span>
          <span class="phase-sub prose">
            The building blocks, one at a time: lifecycle events, the router, fail-safe hooks, the
            memory stack, commands, skills, subagents, and MCP. Start here.
          </span>
          <span class="phase-go mono">Begin Phase 1 →</span>
        </a>
        <a class="phase-card" href={href('phase-2')}>
          <span class="phase-tag mono">PHASE 2 · 8 MODULES</span>
          <span class="phase-title">The Teardown</span>
          <span class="phase-sub prose">
            A guided teardown of the reference harness, layer by layer, up to the second-model
            approval gate that keeps a long, unattended run safe.
          </span>
          <span class="phase-go mono">Begin Phase 2 →</span>
        </a>
      </nav>
    </section>

    <p class="provenance prose">
      Every claim in the Atlas links to the exact source it came from, pinned to commit
      <a href={facts.provenance.settings}>{facts.shortSha}</a> of the reference harness. Nothing here
      is invented for the lesson.
    </p>
  </main>
</BaseLayout>

<style>
  .landing {
    padding-block: var(--sp-12) var(--sp-8);
  }

  /* ── Hero ──────────────────────────────────────────────────────── */
  .kicker {
    color: var(--signal);
    letter-spacing: 0.18em;
    font-size: var(--fs-xs);
    margin: 0 0 var(--sp-4);
  }
  .hero-line {
    font-size: clamp(1.9rem, 5.5vw, var(--fs-3xl));
    max-width: 22ch;
    margin: 0 0 var(--sp-6);
  }
  .tagline {
    color: var(--ink-muted);
    font-size: var(--fs-lg);
    margin: 0 0 var(--sp-8);
    max-width: 60ch;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-bottom: var(--sp-4);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    min-height: var(--target-comfortable);
    padding: 0 var(--sp-6);
    border-radius: var(--radius-panel);
    font-size: var(--fs-base);
    font-weight: 600;
    text-decoration: none;
    border: 1px solid transparent;
    transition:
      background var(--motion-settle) var(--ease-settle),
      border-color var(--motion-settle) var(--ease-settle);
  }
  .btn-primary {
    background: var(--signal);
    color: #1a1206;
  }
  .btn-primary:hover {
    background: #ffc473;
  }
  .btn-ghost {
    color: var(--ink);
    border-color: rgba(232, 235, 240, 0.18);
  }
  .btn-ghost:hover {
    border-color: var(--signal-dim);
    background: var(--surface);
  }
  .meta-line {
    color: var(--ink-faint);
    font-size: var(--fs-xs);
    margin: 0 0 var(--sp-16);
  }

  /* ── Section heads ─────────────────────────────────────────────── */
  .section-h {
    font-size: var(--fs-xl);
    margin: 0 0 var(--sp-6);
    padding-bottom: var(--sp-3);
    border-bottom: var(--border-hairline);
  }

  /* ── What you'll learn ─────────────────────────────────────────── */
  .learn {
    margin-bottom: var(--sp-16);
  }
  .learn-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--sp-5, 20px);
    grid-template-columns: 1fr;
  }
  @media (min-width: 48rem) {
    .learn-grid {
      grid-template-columns: 1fr 1fr;
      column-gap: var(--sp-8);
    }
  }
  .learn-item {
    display: flex;
    gap: var(--sp-4);
    align-items: baseline;
  }
  .learn-num {
    color: var(--signal-dim);
    font-size: var(--fs-sm);
    flex: none;
  }
  .learn-text {
    color: var(--ink-muted);
    font-size: var(--fs-base);
  }

  /* ── Phases ────────────────────────────────────────────────────── */
  .phases {
    margin-bottom: var(--sp-12);
  }
  .phase-nav {
    display: grid;
    gap: var(--sp-6);
    grid-template-columns: 1fr;
  }
  @media (min-width: 48rem) {
    .phase-nav {
      grid-template-columns: 1fr 1fr;
    }
  }
  .phase-card {
    display: grid;
    gap: var(--sp-2);
    padding: var(--sp-6);
    background: var(--surface);
    border: var(--border-hairline);
    border-radius: var(--radius-panel);
    color: var(--ink);
    text-decoration: none;
    transition: border-color var(--motion-settle) var(--ease-settle);
  }
  .phase-card:hover,
  .phase-card:focus-visible {
    border-color: var(--signal-dim);
  }
  .phase-tag {
    color: var(--signal);
    font-size: var(--fs-xs);
    letter-spacing: 0.1em;
  }
  .phase-title {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
  }
  .phase-sub {
    color: var(--ink-muted);
    font-size: var(--fs-sm);
  }
  .phase-go {
    color: var(--signal);
    font-size: var(--fs-sm);
    margin-top: var(--sp-2);
  }

  /* ── Provenance ────────────────────────────────────────────────── */
  .provenance {
    color: var(--ink-faint);
    font-size: var(--fs-sm);
    border-top: var(--border-hairline);
    padding-top: var(--sp-4);
    max-width: 70ch;
  }
</style>
