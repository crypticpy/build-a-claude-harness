---
import Explorable from "../../layouts/Explorable.astro";
import { href } from "../../lib/href";
import { neighbors } from "../../lib/phase1";

const { prev, next } = neighbors("phase-1/mcp");

const scenes = [
  {
    id: "intro",
    eyebrow: "MCP servers",
    title: "Built-in tools reach your computer.",
    body: "Out of the box, Claude Code can read your files and run commands. That's a short, fixed list of tools, and all of it lives on your machine. It can't reach a database, a docs site, or your calendar on its own.",
  },
  {
    id: "plug",
    eyebrow: "Step 1",
    title: "An MCP server plugs in outside tools.",
    body: "MCP is a standard way to connect Claude Code to things beyond your computer. Connect one server and its tools join the list, like a search_docs tool for looking up library documentation.",
  },
  {
    id: "call",
    eyebrow: "Step 2",
    title: "The model calls it like any other tool.",
    body: "Nothing new to learn. The model asks for the tool, the MCP server runs it and sends a result back, exactly the round trip you saw with tool calls. The tool just happens to live outside.",
  },
  {
    id: "many",
    eyebrow: "Step 3",
    title: "Connect as many as you need.",
    body: "Because the plug is standard, any MCP server connects the same way. A docs server, a database, a calendar: each adds its tools to the same list, and the model reaches them all the same way.",
  },
  {
    id: "try",
    eyebrow: "Your turn",
    title: "Plug servers in and out.",
    body: "Connect or disconnect each MCP server and watch the model's list of available tools grow and shrink. Every connected tool is one the model can now call.",
  },
];
---

<Explorable
  title="MCP servers · Lesson 1 · Harness Atlas"
  description="MCP is a standard way to connect Claude Code to tools and data beyond your computer. A connected MCP server adds its tools to the list the model can call, and the model calls them the same way it calls a built-in tool."
  backHref={href("phase-1")}
  backLabel="Lesson 1"
  tag="Part 08 · MCP servers"
  eyebrow="MCP servers"
  h1="Reaching beyond your computer."
  lede="Claude Code's built-in tools touch your own machine: files and commands. An MCP server is a standard plug for outside tools and data, a database, a docs library, a calendar. Once connected, its tools join the list the model can call, and it calls them just like the built-in ones."
  canvasId="mcp-canvas"
  canvasAria="A Claude Code box on the left listing the tools it can call, linked to MCP server cards on the right. Connecting a server adds its tool to the list; a call travels out to the server and a result returns."
  legend={[
    { accent: "context", label: "A tool added by MCP" },
    { accent: "action", label: "A call going out" },
    { accent: "verified", label: "A result coming back" },
  ]}
  outroEyebrow="The takeaway"
  outroTitle="One standard plug, many tools."
  outroBody="MCP lets Claude Code reach tools and data outside your computer through one standard connection, and the model uses them with the same ask-run-result loop as its built-in tools. That's the last stock part. Next, everything at once: watch stock Claude Code build a small program end to end."
  prev={prev}
  next={next}
  fallbackHref="phase-1"
  fallbackLabel="Back to Lesson 1"
>
  {
    scenes.map((s) => (
      <article class="scene" data-scene={s.id}>
        <p class="scene-eyebrow">{s.eyebrow}</p>
        <h2>{s.title}</h2>
        <p>{s.body}</p>
        {s.id === "try" && (
          <div class="controls">
            <button class="ctl" data-server="docs" type="button">
              Docs
            </button>
            <button class="ctl" data-server="db" type="button">
              Database
            </button>
            <button class="ctl" data-server="cal" type="button">
              Calendar
            </button>
          </div>
        )}
      </article>
    ))
  }
</Explorable>
<script>
  import { initMcp } from "../../scripts/mcp";
  initMcp();
</script>
