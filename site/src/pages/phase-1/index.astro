---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhaseTransition from '../../components/heva/PhaseTransition.astro';
import ModuleMenu from '../../components/ModuleMenu.astro';

const mods = (await getCollection('modules'))
  .filter((m) => m.data.phase === 1)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Phase 1: Foundations — Harness Atlas"
  phase="1"
  description="Eight modules, one building block of the harness each. Commit a prediction, see the mechanism, watch it move, then prove you can read it."
>
  <PhaseTransition question="Which events did this harness wire, and what runs at each one?" label="Phase 1 question" />
  <main id="main" class="wrap phase">
    <ModuleMenu
      phase={1}
      name="Foundations"
      question="Which events did this harness wire, and what runs at each one?"
      intro="Eight modules, one building block of the harness each. You commit a prediction, see the mechanism, watch it move, then prove you can read it."
      modules={mods}
    />
  </main>
</BaseLayout>

<style>
  .phase {
    padding-block: var(--sp-12) var(--sp-16);
    min-height: 80dvh;
  }
</style>
