---
import { href } from "../../lib/href";
import { TOPICS } from "../../lib/phase1";

const REPO = "https://github.com/crypticpy/build-a-claude-harness";
const builtCount = TOPICS.filter((t) => t.built).length;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Phase 1 of Harness Atlas: how Claude Code works, one part at a time. The agent loop, tool calls, planning, context and memory, hooks, commands and skills, subagents, and MCP, ending with a stock demo."
    />
    <link rel="icon" href={href("favicon.svg")} />
    <title>Phase 1: How Claude Code works · Harness Atlas</title>
  </head>
  <body>
    <header class="topbar">
      <a class="topbar-back" href={href()}>← Harness Atlas</a>
      <span class="topbar-tag">Phase 1 · How Claude Code works</span>
    </header>

    <main id="main">
      <section class="hero">
        <p class="eyebrow">Phase 1</p>
        <h1>How Claude Code works</h1>
        <p class="lede">
          Claude Code is a harness: the software around an AI model that lets it act on your project.
          This phase takes it apart one part at a time. Each part gets a plain explanation, a picture,
          and something you can try. You don't need to write code to follow it.
        </p>
        <p class="lede-2">
          Start at the top. Each part builds on the one before it, and the last part puts them all
          together on a real task.
        </p>
      </section>

      <section class="topics" aria-label="Phase 1 topics">
        <ol class="topic-list">
          {
            TOPICS.map((t) =>
              t.built ? (
                <li class="topic">
                  <a class="topic-card" href={href(t.path)}>
                    <span class="topic-n">{String(t.n).padStart(2, "0")}</span>
                    <span class="topic-body">
                      <span class="topic-title">{t.title}</span>
                      <span class="topic-blurb">{t.blurb}</span>
                    </span>
                    <span class="topic-go" aria-hidden="true">
                      →
                    </span>
                  </a>
                </li>
              ) : (
                <li class="topic">
                  <div class="topic-card topic-card--soon" aria-disabled="true">
                    <span class="topic-n">{String(t.n).padStart(2, "0")}</span>
                    <span class="topic-body">
                      <span class="topic-title">{t.title}</span>
                      <span class="topic-blurb">{t.blurb}</span>
                    </span>
                    <span class="topic-soon">soon</span>
                  </div>
                </li>
              ),
            )
          }
        </ol>
        <p class="topics-note">
          {builtCount} of {TOPICS.length} parts are ready. The rest are on the way.
        </p>
      </section>

      <section class="closing">
        <p class="closing-links">
          <a href={href("agent-loop")}>Start with the agent loop →</a>
          <a href={href("phase-2")}>Phase 2: Customizing Claude Code</a>
          <a href={REPO} rel="noopener">Source on GitHub</a>
        </p>
      </section>
    </main>

    <style is:global>
      :root {
        --paper: #fbfaf6;
        --paper-2: #ffffff;
        --ink: #221f1a;
        --ink-soft: #5c554b;
        --ink-faint: #968d7d;
        --hair: #e6e0d4;
        --hair-strong: #d6cdbb;
        --context: #2f6bd8;
        --action: #c9740a;
        --verified: #1f9a63;
        --risk: #d6453f;
        --serif: "Iowan Old Style", "Palatino Linotype", Palatino, "Book Antiqua", Georgia, ui-serif,
          serif;
        --sans: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial,
          sans-serif;
        --mono: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
      }

      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--sans);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px clamp(20px, 5vw, 56px);
        border-bottom: 1px solid var(--hair);
        position: sticky;
        top: 0;
        background: color-mix(in srgb, var(--paper) 92%, transparent);
        z-index: 20;
      }
      .topbar-back {
        color: var(--ink);
        text-decoration: none;
        font-weight: 600;
        font-size: 15px;
      }
      .topbar-back:hover {
        color: var(--context);
      }
      .topbar-tag {
        font-family: var(--mono);
        font-size: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--ink-faint);
      }

      main {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 clamp(20px, 5vw, 56px);
      }

      .eyebrow {
        font-family: var(--mono);
        font-size: 12.5px;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        color: var(--action);
        margin: 0 0 14px;
      }

      .hero {
        padding: clamp(52px, 10vh, 112px) 0 clamp(28px, 5vh, 52px);
        max-width: min(70ch, 100%);
      }
      .hero h1 {
        font-family: var(--serif);
        font-weight: 600;
        font-size: clamp(34px, 6vw, 58px);
        line-height: 1.07;
        letter-spacing: -0.015em;
        margin: 0 0 26px;
      }
      .lede {
        font-size: clamp(18px, 2.2vw, 22px);
        line-height: 1.55;
        color: var(--ink-soft);
        max-width: 60ch;
        margin: 0 0 18px;
      }
      .lede-2 {
        font-size: clamp(16px, 1.9vw, 19px);
        line-height: 1.55;
        color: var(--ink-soft);
        max-width: 60ch;
        margin: 0;
      }

      /* ---- topic list ---- */
      .topics {
        padding-top: clamp(24px, 5vh, 48px);
      }
      .topic-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 12px;
      }
      .topic-card {
        display: flex;
        align-items: center;
        gap: clamp(14px, 2.4vw, 26px);
        padding: clamp(16px, 2.2vw, 22px) clamp(18px, 2.4vw, 26px);
        background: var(--paper-2);
        border: 1px solid var(--hair);
        border-radius: 14px;
        text-decoration: none;
        color: var(--ink);
        transition:
          border-color 0.16s ease,
          transform 0.12s ease,
          box-shadow 0.16s ease;
      }
      a.topic-card:hover {
        transform: translateY(-2px);
        border-color: var(--hair-strong);
        box-shadow:
          0 1px 2px rgba(40, 38, 32, 0.04),
          0 18px 38px -28px rgba(40, 38, 32, 0.26);
      }
      .topic-card--soon {
        opacity: 0.6;
        background: transparent;
        border-style: dashed;
      }
      .topic-n {
        font-family: var(--mono);
        font-size: clamp(15px, 2vw, 18px);
        font-weight: 600;
        color: var(--action);
        flex: none;
        width: 2.2em;
      }
      .topic-body {
        display: flex;
        flex-direction: column;
        gap: 3px;
        flex: 1;
        min-width: 0;
      }
      .topic-title {
        font-family: var(--serif);
        font-size: clamp(19px, 2.4vw, 24px);
        font-weight: 600;
        line-height: 1.15;
      }
      .topic-blurb {
        font-size: clamp(14px, 1.7vw, 16px);
        line-height: 1.5;
        color: var(--ink-soft);
      }
      .topic-go {
        font-size: 20px;
        color: var(--context);
        flex: none;
      }
      .topic-soon {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--ink-faint);
        border: 1px solid var(--hair-strong);
        border-radius: 999px;
        padding: 3px 10px;
        flex: none;
      }
      .topics-note {
        font-family: var(--mono);
        font-size: 12.5px;
        color: var(--ink-faint);
        margin: 22px 2px 0;
      }

      /* ---- closing ---- */
      .closing {
        padding: clamp(40px, 8vh, 96px) 0 clamp(72px, 14vh, 140px);
      }
      .closing-links {
        display: flex;
        flex-wrap: wrap;
        gap: 14px 28px;
        margin: 0;
        border-top: 1px solid var(--hair);
        padding-top: 24px;
      }
      .closing-links a {
        color: var(--context);
        text-decoration: none;
        font-weight: 600;
        font-size: 16px;
      }
      .closing-links a:hover {
        text-decoration: underline;
      }

      @media (max-width: 620px) {
        .topic-card {
          align-items: flex-start;
        }
        .topic-go {
          align-self: center;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        .topic-card {
          transition: none;
        }
      }
    </style>
  </body>
</html>
