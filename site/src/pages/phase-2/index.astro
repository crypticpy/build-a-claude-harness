---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhaseTransition from '../../components/heva/PhaseTransition.astro';
import ModuleMenu from '../../components/ModuleMenu.astro';

const mods = (await getCollection('modules'))
  .filter((m) => m.data.phase === 2)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Lesson 2: The Teardown — Harness Atlas"
  phase="2"
  description="One descent through the reference harness, layer by layer, ending on the question that makes autonomy safe: how does it run for hours without you?"
>
  <PhaseTransition question="How does it run for hours without you?" label="Lesson 2 question" />
  <main id="main" class="wrap phase">
    <ModuleMenu
      phase={2}
      name="The Teardown"
      question="How does it run for hours without you?"
      intro="One descent through the reference harness, layer by layer. Each module lights one region of the whole-loop map you built in Lesson 1, ending on the second-model gate that makes a long, unattended run safe."
      modules={mods}
    />
  </main>
</BaseLayout>

<style>
  .phase {
    padding-block: var(--sp-12) var(--sp-16);
    min-height: 80dvh;
  }
</style>
