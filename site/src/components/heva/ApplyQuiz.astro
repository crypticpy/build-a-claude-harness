---
// The Apply beat's JS-off floor: a single ungated check. CSS-only reveal of the
// correct option and per-option feedback after commit. The QuizEngine island
// enhances this same markup (aria-live verdict, first-try recording, answer
// key); it is never the only path to the answer.
import QuizEngine from '../../islands/QuizEngine';
interface Option {
  id: string;
  label: string;
  feedback?: string;
}
interface Props {
  id: string;
  question: string;
  options: Option[];
  correct: string;
  mode?: 'outcome' | 'assertion-reason' | 'confidence' | 'misconception';
}
const { id, question, options, correct, mode = 'outcome' } = Astro.props;
const name = `aq-${id}`;
---

<form class="apply-quiz" data-aq={id}>
  <fieldset>
    <legend class="aq-question">{question}</legend>
    <div class="aq-options">
      {
        options.map((o) => (
          <div class="aq-option">
            <input
              type="radio"
              class="aq-input"
              id={`${name}-${o.id}`}
              name={name}
              value={o.id}
              data-correct={o.id === correct ? 'true' : 'false'}
            />
            <label for={`${name}-${o.id}`} class="aq-label">
              {o.label}
              {o.feedback && <span class="aq-feedback">{o.feedback}</span>}
            </label>
          </div>
        ))
      }
    </div>
  </fieldset>
  <QuizEngine client:visible={{ rootMargin: '300px' }} targetId={id} correct={correct} options={options} mode={mode} />
</form>
