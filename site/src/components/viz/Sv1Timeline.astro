---
// SV-1 Lifecycle Timeline — the hero visualization. ONE StationModel rendered
// three ways: the animated SVG (token rides the wire, station lights, drawer
// opens), the data twin (a first-class table, the primary accessible surface),
// and the static no-JS fallback (the same SVG, frozen at step 0). All from a
// single build pass over the provenance-gated model.
import DiagramFrame from '../diagram/DiagramFrame.astro';
import FlowNode from '../diagram/FlowNode.astro';
import TypedEdge from '../diagram/TypedEdge.astro';
import Legend from '../diagram/Legend.astro';
import Figure from '../diagram/Figure.astro';
import TracePlayer from '../../islands/TracePlayer';
import { buildSv1, stations } from '../../lib/sv1';

const { model, steps, wireD, fanModules } = buildSv1();
const id = 'sv1';
const start = steps[0];
---

<Figure id={id} label="The six moments in a session: picture or table view">
  <div slot="svg">
    <TracePlayer client:visible={{ rootMargin: '600px' }} figureId={id} steps={steps} autoplay />

    <DiagramFrame width={model.width} height={model.height} label="One work session moves along a line, stopping at six moments. At five of them this harness attaches a helper; the moment 'about to use a tool' is left empty, shown as a dashed hollow.">
      <path class="wire" d={wireD}></path>
      {model.edges.map((edge) => <TypedEdge model={model} edge={edge} />)}
      {model.nodes.map((node) => <FlowNode node={node} />)}
      {
        stations.map((s, i) => (
          <text
            class={`station-gloss${s.subscribed ? '' : ' is-empty'}`}
            x={model.nodes[i].x}
            y={model.nodes[i].y - 42}
            text-anchor="middle"
          >
            {s.plain}
          </text>
        ))
      }
      <ellipse
        class="token"
        cx="0"
        cy="0"
        rx="9"
        ry="7"
        style={`transform: translate(${start.tokenX}px, ${start.tokenY}px)`}
        aria-hidden="true"
      ></ellipse>
      {
        fanModules.map((_, k) => (
          <ellipse class="token capsule" data-capsule={k} cx="0" cy="0" rx="7" ry="6" aria-hidden="true" />
        ))
      }
    </DiagramFrame>

    <div class="drawers">
      {
        stations.map((s, i) => (
          <div class="drawer" data-drawer={s.id} hidden={i !== 0}>
            <div class="drawer-head">
              <span class="drawer-title">{s.plain}</span>
              <code class="drawer-id">{s.id}</code>
              {s.subscribed ? (
                <span class="drawer-tag is-fact">helper attached · real at SHA</span>
              ) : (
                <span class="drawer-tag is-unsub">nothing attached</span>
              )}
              {s.fanout && <span class="drawer-tag">two helpers</span>}
            </div>
            <div class="drawer-rows">
              {s.matchers.length === 0 ? (
                <p class="drawer-note">
                  This harness attaches nothing at this moment. The empty spot is
                  itself the fact: the moment is real, but nothing runs here.
                </p>
              ) : (
                s.matchers.map((m) => (
                  <dl class="drawer-row">
                    <dt>applies to</dt>
                    <dd>
                      <code>{m.matcher}</code>
                    </dd>
                    <dt>runs</dt>
                    <dd>
                      <code>{m.arg}</code>
                    </dd>
                  </dl>
                ))
              )}
              {s.contract && (
                <dl class="drawer-row">
                  <dt>stdin</dt>
                  <dd>
                    <code>{s.contract.stdin}</code>
                  </dd>
                  <dt>stdout</dt>
                  <dd>
                    <code>{s.contract.stdout}</code>
                  </dd>
                </dl>
              )}
            </div>
            <p class="drawer-note">{s.note}</p>
          </div>
        ))
      }
    </div>

    <Legend edges={['event']} nodes={['router']} />
  </div>

  <table slot="data" class="twin">
    <caption>
      The six moments in one work session, in order. This harness attaches a helper
      at five of them; the moment “about to use a tool” stays empty. Real at SHA
      {model.sha}.
    </caption>
    <thead>
      <tr>
        <th scope="col">#</th>
        <th scope="col">Moment</th>
        <th scope="col">Helper?</th>
        <th scope="col">Runs</th>
        <th scope="col">stdin → stdout</th>
        <th scope="col">Note</th>
      </tr>
    </thead>
    <tbody>
      {
        stations.map((s, i) => (
          <tr data-step={i}>
            <td>{i + 1}</td>
            <td class={s.subscribed ? 'twin-fact' : 'twin-unsub'}>
              {s.plain}
              <code class="twin-id">{s.id}</code>
            </td>
            <td>{s.subscribed ? (s.fanout ? 'yes · 2 helpers' : 'yes') : 'no'}</td>
            <td>
              {s.matchers.length === 0 ? (
                <span class="twin-unsub">—</span>
              ) : (
                s.matchers.map((m) => (
                  <div>
                    <code>{m.matcher}</code> → <code>{m.arg}</code>
                  </div>
                ))
              )}
            </td>
            <td>
              {s.contract ? (
                <code>
                  {s.contract.stdin} → {s.contract.stdout}
                </code>
              ) : (
                <span class="twin-unsub">—</span>
              )}
            </td>
            <td>{s.note}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</Figure>

<style>
  /* Plain-English caption floating above each station, so the picture reads
     without knowing the platform's event names. */
  .station-gloss {
    fill: var(--ink-muted);
    font-size: 13px;
    font-weight: 650;
    letter-spacing: 0.005em;
  }
  .station-gloss.is-empty {
    fill: var(--ink-faint);
    font-style: italic;
  }
  @media (forced-colors: active) {
    .station-gloss {
      fill: CanvasText;
    }
  }

  /* The real event name, kept as a quiet technical chip beside the plain name. */
  .drawer-id {
    margin-inline-start: 0.5ch;
    font-size: 0.78em;
    color: var(--ink-faint);
  }
  .twin-id {
    display: block;
    margin-block-start: 2px;
    font-size: 0.82em;
    color: var(--ink-faint);
  }
</style>
