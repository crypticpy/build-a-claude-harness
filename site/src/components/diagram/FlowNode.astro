---
import { nodePath, nodeRect, type DiagramNode } from '../../lib/diagram';

interface Props {
  node: DiagramNode;
  lit?: boolean;
}
const { node, lit = false } = Astro.props;
const shape = nodePath(node);
const r = nodeRect(node);
const unsub = node.trust === 'unpinnable';
const labelY = r.y + r.h + 16;
---

<g
  class:list={['node-group', { 'is-lit': lit }]}
  data-node-id={node.id}
  data-node-kind={node.kind}
>
  <rect class="focus-rect" x={r.x - 6} y={r.y - 6} width={r.w + 12} height={r.h + 12}></rect>
  {
    shape.tag === 'rect' ? (
      <rect
        class:list={['node', { 'node--unsub': unsub }]}
        x={r.x}
        y={r.y}
        width={r.w}
        height={r.h}
        rx={shape.rx}
      />
    ) : (
      <path class:list={['node', { 'node--unsub': unsub }]} d={shape.d} />
    )
  }
  {
    !unsub &&
      (shape.tag === 'rect' ? (
        <rect class="node-fill" x={r.x} y={r.y} width={r.w} height={r.h} rx={shape.rx} />
      ) : (
        <path class="node-fill" d={shape.d} />
      ))
  }
  <text class="node-label" x={node.x} y={labelY}>{node.label}</text>
</g>
